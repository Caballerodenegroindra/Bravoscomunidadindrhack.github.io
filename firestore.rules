// ═══════════════════════════════════════════════════════════
// REGLAS COMPLETAS DE FIRESTORE — Academia Indrhack
// ═══════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────────────────────
    // FUNCIONES AUXILIARES
    // ───────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        myProfile().rol == 'administrador';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function canAccessRoom(roomId) {
      let roomPath = /databases/$(database)/documents/chat_rooms/$(roomId);
      return !exists(roomPath) ||
        get(roomPath).data.type != 'dm' ||
        request.auth.uid in get(roomPath).data.participants;
    }

    // ───────────────────────────────────────────────────────
    // USUARIOS
    // ───────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && request.resource.data.rol == 'usuario'
        && request.resource.data.estado == 'pendiente';

      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.rol    == resource.data.rol &&
        request.resource.data.estado == resource.data.estado &&
        request.resource.data.rango  == resource.data.rango &&
        request.resource.data.get('puntos', 0)      == resource.data.get('puntos', 0) &&
        request.resource.data.get('puntosTotal', 0) == resource.data.get('puntosTotal', 0)
      );

      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────────────
    // CURSOS (catálogo público)
    // ───────────────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────────────
    // NOTIFICACIONES
    // ───────────────────────────────────────────────────────
    // La mayoría (cuenta, quiz, proyecto, curso nuevo, clase en
    // vivo) las crea solo el admin. Excepción: "respuesta_hilo",
    // que puede crearla cualquier usuario logueado porque se
    // dispara cuando OTRO usuario (no el admin) responde un
    // mensaje en un hilo del chat. Se exige además que la
    // notificación sea para otra persona, nunca para uno mismo.
    match /notificaciones/{docId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.tipo == 'respuesta_hilo' &&
        request.resource.data.uid != request.auth.uid
      );
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leida']);
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ───────────────────────────────────────────────────────
    // CLASES DE TERMUX
    // ───────────────────────────────────────────────────────
    match /clases_termux/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /cursos_aprobados/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /proyectos_base/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /proyectos/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────────────
    // QUIZZES
    // ───────────────────────────────────────────────────────
    match /quiz_submissions/{subId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente';
      allow update, delete: if isAdmin();
    }

    match /quiz_logros/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /user_titles/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────────────
    // NOTICIAS Y CONFIGURACIÓN DEL SITIO (público)
    // ───────────────────────────────────────────────────────
    match /noticias/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /config/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────────────
    // CHAT
    // ───────────────────────────────────────────────────────
    match /chat_rooms/{roomId} {
      allow read: if isSignedIn() &&
        (resource == null || resource.data.type != 'dm' || request.auth.uid in resource.data.participants);

      allow create: if isSignedIn() && (
        request.resource.data.type != 'dm' ||
        (request.auth.uid in request.resource.data.participants &&
         request.resource.data.participants.size() == 2)
      );

      allow update: if isSignedIn() &&
        (resource.data.type != 'dm' || request.auth.uid in resource.data.participants);

      allow delete: if isAdmin();
    }

    match /chat_messages/{msgId} {
      allow read: if isSignedIn() && canAccessRoom(resource.data.roomId);
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && canAccessRoom(request.resource.data.roomId);
      allow update: if isSignedIn() && canAccessRoom(resource.data.roomId);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /chat_replies/{replyId} {
      allow read: if isSignedIn() && canAccessRoom(resource.data.roomId);
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && canAccessRoom(request.resource.data.roomId);
      allow update: if false;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ───────────────────────────────────────────────────────
    // CLASES EN VIVO
    // ───────────────────────────────────────────────────────
    match /live_classes/{sessionId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();

      match /steps/{stepId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    match /live_progress/{progressId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && progressId == request.resource.data.sessionId + '_' + request.auth.uid;

      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.sessionId == resource.data.sessionId &&
        request.resource.data.unlockedStep >= resource.data.unlockedStep
      );

      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────────────
    // PRESENCIA POR SALA
    // ───────────────────────────────────────────────────────
    match /room_presence/{presenceId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && presenceId == request.resource.data.roomId + '_' + request.auth.uid;
      allow delete: if isSignedIn() &&
        (presenceId == resource.data.roomId + '_' + request.auth.uid || isAdmin());
    }
  }
}
